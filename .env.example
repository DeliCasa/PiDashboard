# PiDashboard Environment Variables

# Pi hostname/IP for Vite dev proxy targets (default: 192.168.1.124)
# VITE_PI_HOST=192.168.1.124

# Connect RPC base URL (default: /rpc for same-origin via Vite proxy)
# Set to full URL for Cloudflare Tunnel or non-default deployment:
#   VITE_PI_RPC_URL=https://raspberrypi.tail345cd5.ts.net/rpc
# VITE_PI_RPC_URL=/rpc

# API key for protected RPCs (CaptureImage, ReconcileCameras)
# VITE_API_KEY=your-api-key-here

# Auth bypass for development (set to "true" to skip API key check)
# VITE_BYPASS_AUTH=false
